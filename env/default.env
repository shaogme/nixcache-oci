# nixcache-oci environment configuration

# 如果设为 1，工作流和测试脚本会加载对应的 example 环境变量。
# 设为 0 或注释掉，以使用下方您自定义的配置。
NIXCACHE_EXAMPLE=1

# 自定义配置（在 NIXCACHE_EXAMPLE 不为 1 时生效）
# 构建模式：flake 或 non-flake
NIXCACHE_MODE=flake

# 对于 flake 模式：包含 flake.nix 的目录路径（例如 . 或自定义路径）
NIXCACHE_CONFIG_DIR=.

# 对于 non-flake 模式：
# NIXCACHE_FILE=default.nix
# NIXCACHE_ATTRIBUTES=my-package
